# Environment variables for SEO Content Agent

# Masumi Integration
MASUMI_API_KEY=your_masumi_api_key_here
MASUMI_BASE_URL=https://api.masumi.io
WEBHOOK_SECRET=your_webhook_secret_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost,http://localhost:3000

# Agent Configuration
DEFAULT_AGENT_NAME=SEO Content Agent
LOG_LEVEL=INFO

# Database (if needed)
DATABASE_URL=sqlite:///./seo_agent.db

# External APIs
# Add any other API keys or endpoints here
